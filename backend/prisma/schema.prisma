datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum EventStatus {
  pending
  approved
  rejected
  finished
  cancelled
}

enum TicketStatus {
  active
  sold_out
  paused
  hidden
  expired
}

enum OrderStatus {
  pending
  processing
  paid
  cancelled
  refunded
  failed
}

enum DiscountType {
  PERCENTAGE
  FIXED
  PERCENTAGE_FEE
}

model SystemConfig {
  id            String   @id @default(uuid())
  platformFee   Float    @default(0.08)
  minFee        Float    @default(2.00)
  premiumPrice  Float    @default(100.00)
  standardPrice Float    @default(2.00)
  updatedAt     DateTime @updatedAt

  @@map("system_config")
}

model User {
  id                       String   @id @default(uuid())
  name                     String
  email                    String   @unique
  password                 String?
  isAdmin                  Boolean  @default(false)
  stripeAccountId          String?
  stripeOnboardingComplete Boolean  @default(false)
  profilePicture           String?
  coverPicture             String?
  bio                      String?
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  eventsOrganized          Event[]  @relation("EventOrganizer")
  favoritedEvents          Event[]  @relation("UserFavorites")
  orders                   Order[]
  tickets                  Ticket[]

  @@map("users")
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  description String?
  instagram   String?
  coupons     Coupon[]
  events      Event[]
  createdAt   DateTime @default(now())

  @@map("partners")
}

model Event {
  id                   String      @id @default(uuid())
  title                String
  description          String
  imageUrl             String
  city                 String
  location             String
  category             String
  ageRating            String?
  status               EventStatus @default(pending)
  externalUrl          String? 
  isInformational      Boolean     @default(false)
  priceFrom            Float?  
  refundPolicy         String
  termsAndConditions   String?
  isFeatured           Boolean     @default(false)
  isFeaturedRequested  Boolean     @default(false)
  highlightStatus      String      @default("none")
  highlightFee         Float       @default(0)
  highlightTier        String?
  highlightPaymentLink String?
  highlightDuration    Int?
  highlightExpiresAt   DateTime?
  eventDate            DateTime
  sessions             Json?
  formSchema           Json?
  organizerInfo        Json?
  organizerId          String
  organizer            User        @relation("EventOrganizer", fields: [organizerId], references: [id])
  favoritedBy          User[]      @relation("UserFavorites")
  partnerId            String?
  partner              Partner?    @relation(fields: [partnerId], references: [id])
  ticketTypes          TicketType[]
  coupons              Coupon[]
  orders               Order[]
  tickets              Ticket[]

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@map("events")
}

model TicketType {
  id           String       @id @default(uuid())
  eventId      String
  event        Event        @relation(fields: [eventId], references: [id])
  name         String       @default("Ingresso")
  description  String?
  price        Float
  quantity     Int
  sold         Int          @default(0)
  batchName    String?
  salesStart   DateTime?
  salesEnd     DateTime?
  activityDate DateTime?
  startTime    String?
  endTime      String?
  isHalfPrice  Boolean      @default(false)
  category     String?
  maxPerUser   Int          @default(4)
  minPerUser   Int          @default(1)
  status       TicketStatus @default(active)
  tickets      Ticket[]
  orderItems   OrderItem[]

  @@map("ticket_types")
}

model Coupon {
  id                String   @id @default(uuid())
  code              String   @unique
  description       String?
  discountType      String
  discountValue     Float
  partner           String
  maxUses           Int?
  usedCount         Int      @default(0)
  usageLimitPerUser Int      @default(1)
  minPurchaseAmount Float?
  validFrom         DateTime?
  validUntil        DateTime?
  isActive          Boolean  @default(true)
  expiresAt         DateTime?
  eventId           String?
  event             Event?   @relation(fields: [eventId], references: [id])
  partnerId         String?
  partnerRef        Partner? @relation(fields: [partnerId], references: [id])
  orders            Order[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("coupons")
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  eventId         String
  event           Event       @relation(fields: [eventId], references: [id])
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  items           OrderItem[]
  tickets         Ticket[]
  subtotal        Float
  discountAmount  Float       @default(0)
  platformFee     Float
  totalAmount     Float
  status          OrderStatus @default(pending)
  paymentIntentId String?
  paymentMethod   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id           String     @id @default(uuid())
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id])
  ticketTypeId String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  quantity     Int
  unitPrice    Float

  @@map("order_items")
}

model Ticket {
  id              String     @id @default(uuid())
  ticketTypeId    String
  ticketType      TicketType @relation(fields: [ticketTypeId], references: [id])
  eventId         String
  event           Event      @relation(fields: [eventId], references: [id])
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  orderId         String
  order           Order      @relation(fields: [orderId], references: [id])
  qrCodeData      String     @unique
  price           Float
  status          String     @default("valid")
  participantData Json?
  usedAt          DateTime?
  createdAt       DateTime   @default(now())

  @@map("tickets")
}